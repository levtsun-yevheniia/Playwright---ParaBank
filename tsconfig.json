{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "types": ["node", "@playwright/test"],

    "allowJs": false,
    "esModuleInterop": true,

    "resolveJsonModule": true,

    "strict": true,

    "skipLibCheck": true
  },

  "include": ["tests", "pages", "fixtures", "utils", "playwright.config.ts"]
}
